# SARTHI backend environment — copy to .env and fill in real values.
# .env is git-ignored; NEVER commit real keys.

# --- NVIDIA Build (primary LLM provider, OpenAI-compatible) ---
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Default reasoning model (free on NVIDIA Build). LLM-agnostic: change this
# one line to swap models. Verified-working free options:
#   meta/llama-3.3-70b-instruct          (fast, capable — current default)
#   nvidia/llama-3.3-nemotron-super-49b-v1.5
#   nvidia/nemotron-3-super-120b-a12b
#   deepseek-ai/deepseek-v4-flash
SARTHI_MODEL_DEFAULT=meta/llama-3.3-70b-instruct

# --- Other free providers (add when needed) ---
# GOOGLE_API_KEY=        # Google AI Studio (Hindi fallback: Gemini 2.0 Flash)
# GROQ_API_KEY=          # Groq (voice/speed: Llama-3.3-70B)
